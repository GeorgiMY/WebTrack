@page
@model IndexModel
@{
    ViewData["Title"] = "My Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h3 class="fw-bold mb-4 text-dark">@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-8 col-lg-7">
        <form id="profile-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small fw-semibold mb-3" role="alert"></div>

            <div class="form-floating mb-4">
                <input asp-for="Username" class="form-control bg-light" placeholder="Username" disabled />
                <label asp-for="Username" class="text-secondary"><i class="bi bi-person-badge me-1"></i> Username</label>
            </div>

            <div class="form-floating mb-4">
                <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Phone number" />
                <label asp-for="Input.PhoneNumber" class="text-secondary"><i class="bi bi-telephone me-1"></i> Phone Number</label>
                <span asp-validation-for="Input.PhoneNumber" class="text-danger small fw-semibold mt-1 d-block"></span>
            </div>

            <button id="update-profile-button" type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                Save Changes <i class="bi bi-check2 ms-1"></i>
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}