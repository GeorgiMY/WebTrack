@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h3 class="fw-bold mb-4 text-dark">@ViewData["Title"]</h3>

<div class="row">
    <div class="col-md-9 col-lg-8">
        <p class="text-muted mb-4">Your account contains personal data that you have given us. This page allows you to download or permanently delete that data.</p>

        <div class="card border-0 shadow-sm mb-4 bg-light">
            <div class="card-body d-flex justify-content-between align-items-center p-4">
                <div>
                    <h6 class="fw-bold mb-1"><i class="bi bi-cloud-download me-1 text-primary"></i> Download Your Data</h6>
                    <span class="small text-muted">Get a copy of all data associated with your account.</span>
                </div>
                <form id="download-data" asp-page="DownloadPersonalData" method="post" class="m-0">
                    <button class="btn btn-outline-primary rounded-pill fw-semibold px-4" type="submit">Download</button>
                </form>
            </div>
        </div>

        <div class="card border-danger shadow-sm" style="background-color: #fff5f5;">
            <div class="card-body p-4">
                <h6 class="fw-bold text-danger mb-2"><i class="bi bi-exclamation-triangle-fill me-1"></i> Danger Zone</h6>
                <p class="small text-danger mb-3">
                    <strong>Deleting this data will permanently remove your account.</strong> This action cannot be undone or recovered.
                </p>
                <a id="delete" asp-page="DeletePersonalData" class="btn btn-danger rounded-pill fw-bold px-4 shadow-sm">
                    Delete Account & Data
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}