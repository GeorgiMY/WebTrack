@page
@model ExternalLoginsModel
@{
    ViewData["Title"] = "External Logins";
    ViewData["ActivePage"] = ManageNavPages.ExternalLogins;
}

<h3 class="fw-bold mb-4 text-dark">@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

@if (Model.CurrentLogins?.Count > 0)
{
    <h5 class="fw-bold text-secondary mb-3 fs-6 text-uppercase tracking-wide">Connected Accounts</h5>
    <div class="card border-0 shadow-sm mb-5">
        <ul class="list-group list-group-flush rounded-3">
            @foreach (var login in Model.CurrentLogins)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center p-3">
                    <span id="@($"login-provider-{login.LoginProvider}")" class="fw-semibold text-dark">
                        <i class="bi bi-shield-check text-success me-2"></i> @login.ProviderDisplayName
                    </span>
                    @if (Model.ShowRemoveButton)
                    {
                        <form id="@($"remove-login-{login.LoginProvider}")" asp-page-handler="RemoveLogin" method="post" class="m-0">
                            <input asp-for="@login.LoginProvider" name="LoginProvider" type="hidden" />
                            <input asp-for="@login.ProviderKey" name="ProviderKey" type="hidden" />
                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-semibold" title="Remove this @login.ProviderDisplayName login from your account">
                                Disconnect
                            </button>
                        </form>
                    }
                </li>
            }
        </ul>
    </div>
}

@if (Model.OtherLogins?.Count > 0)
{
    <h5 class="fw-bold text-secondary mb-3 fs-6 text-uppercase tracking-wide">Connect Another Service</h5>
    <form id="link-login-form" asp-page-handler="LinkLogin" method="post">
        <div class="d-flex flex-wrap gap-2">
            @foreach (var provider in Model.OtherLogins)
            {
                <button id="@($"link-login-button-{provider.Name}")" type="submit" class="btn btn-outline-primary rounded-pill fw-semibold shadow-sm px-4" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">
                    <i class="bi bi-link me-1"></i> Connect @provider.DisplayName
                </button>
            }
        </div>
    </form>
}