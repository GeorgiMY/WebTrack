@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h3 class="fw-bold mb-4 text-dark">@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-8 col-lg-7">
        <form id="change-password-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small fw-semibold mb-3" role="alert"></div>

            <div class="form-floating mb-4">
                <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Old password" />
                <label asp-for="Input.OldPassword" class="text-secondary"><i class="bi bi-unlock me-1"></i> Current Password</label>
                <span asp-validation-for="Input.OldPassword" class="text-danger small fw-semibold mt-1 d-block"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="New password" />
                <label asp-for="Input.NewPassword" class="text-secondary"><i class="bi bi-lock me-1"></i> New Password</label>
                <span asp-validation-for="Input.NewPassword" class="text-danger small fw-semibold mt-1 d-block"></span>
            </div>

            <div class="form-floating mb-4">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Confirm password" />
                <label asp-for="Input.ConfirmPassword" class="text-secondary"><i class="bi bi-check-circle me-1"></i> Confirm New Password</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small fw-semibold mt-1 d-block"></span>
            </div>

            <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                Update Password <i class="bi bi-shield-check ms-1"></i>
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}