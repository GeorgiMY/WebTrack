@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout) && parentLayout != null)
    {
        Layout = parentLayout.ToString();
    }
    else
    {
        Layout = "/Areas/Identity/Pages/_Layout.cshtml";
    }
}

<style>
    /* Scoped styling for the account dashboard */
    .account-sidebar .nav-link {
        color: #5f6368;
        border-radius: 8px;
        padding: 0.75rem 1.25rem;
        font-weight: 500;
        transition: all 0.2s ease;
        margin-bottom: 0.25rem;
    }

        .account-sidebar .nav-link:hover {
            background-color: #f8f9fa;
            color: #4facfe;
        }

        .account-sidebar .nav-link.active {
            background-color: rgba(79, 172, 254, 0.1) !important;
            color: #4facfe !important;
            font-weight: 600;
        }

    .manage-card {
        border-radius: 12px;
        overflow: hidden;
        background-color: white;
    }

    .manage-card-accent {
        height: 6px;
        background: linear-gradient(90deg, #4facfe 0%, #00f2fe 100%);
    }

    .form-control:focus {
        border-color: #4facfe;
        box-shadow: 0 0 0 0.25rem rgba(79, 172, 254, 0.25);
    }
</style>

<div class="container py-5">

    <div class="mb-5 border-bottom pb-3">
        <h2 class="fw-bold text-dark mb-1">Account Settings</h2>
        <p class="text-muted mb-0">Manage your profile, security preferences, and personal data.</p>
    </div>

    <div class="row g-4">
        <div class="col-12 col-md-4 col-lg-3 account-sidebar">
            <partial name="_ManageNav" />
        </div>

        <div class="col-12 col-md-8 col-lg-9">
            <div class="card manage-card shadow-sm border-0">
                <div class="manage-card-accent"></div>
                <div class="card-body p-4 p-md-5">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}