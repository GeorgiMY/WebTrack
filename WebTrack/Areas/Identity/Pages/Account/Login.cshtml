@page
@using Microsoft.AspNetCore.Authentication
@model LoginModel

@{
    // Changed title to better SaaS copywriting
    ViewData["Title"] = "Welcome Back";
}

<style>
    /* Scoped styles to match our theme */
    .form-card {
        border-radius: 12px;
        overflow: hidden;
        background-color: white;
    }

    .card-accent {
        height: 6px;
        background: linear-gradient(90deg, #4facfe 0%, #00f2fe 100%);
    }

    .form-control:focus {
        border-color: #4facfe;
        box-shadow: 0 0 0 0.25rem rgba(79, 172, 254, 0.25);
    }

    .form-control {
        background-color: #f8f9fa;
    }

    /* Elegant line divider for external logins */
    .divider {
        display: flex;
        align-items: center;
        text-align: center;
        color: #adb5bd;
    }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid #dee2e6;
        }

        .divider:not(:empty)::before {
            margin-right: .75em;
        }

        .divider:not(:empty)::after {
            margin-left: .75em;
        }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6 col-xl-5">

            <div class="text-center mb-4">
                <i class="bi bi-activity fs-1" style="color: #4facfe;"></i>
                <h2 class="fw-bold text-dark mt-2">@ViewData["Title"]</h2>
                <p class="text-muted">Sign in to your WebTrack dashboard.</p>
            </div>

            <div class="card form-card shadow-sm border-0">
                <div class="card-accent"></div>

                <div class="card-body p-4 p-md-5">
                    <form id="account" method="post">

                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 fw-semibold" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="text-secondary"><i class="bi bi-envelope me-1"></i> Email address</label>
                            <span asp-validation-for="Input.Email" class="text-danger small fw-semibold"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.Password" class="text-secondary"><i class="bi bi-lock me-1"></i> Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger small fw-semibold"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                <label class="form-check-label text-muted small user-select-none" asp-for="Input.RememberMe">
                                    @Html.DisplayNameFor(m => m.Input.RememberMe)
                                </label>
                            </div>
                            <a id="forgot-password" asp-page="./ForgotPassword" class="small text-decoration-none fw-semibold" style="color: #4facfe;">Forgot password?</a>
                        </div>

                        <button id="login-submit" type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold shadow-sm mb-4">
                            Sign In <i class="bi bi-arrow-right ms-1"></i>
                        </button>

                        <div class="text-center small">
                            <span class="text-muted">Don't have an account?</span>
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none fw-semibold ms-1" style="color: #4facfe;">Create one</a>
                            <br />
                            <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="text-muted text-decoration-none mt-2 d-inline-block custom-hover">Resend email confirmation</a>
                        </div>
                    </form>

                    @{
                        if ((Model.ExternalLogins?.Count ?? 0) > 0)
                        {
                            <div class="divider my-4 small fw-bold tracking-wide">OR CONTINUE WITH</div>

                            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                                <div class="d-grid gap-2">
                                    @foreach (AuthenticationScheme? provider in Model.ExternalLogins!)
                                    {
                                        <button type="submit" class="btn btn-outline-secondary rounded-pill fw-semibold text-dark" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">
                                            <i class="bi bi-shield-lock me-1"></i> @provider.DisplayName
                                        </button>
                                    }
                                </div>
                            </form>
                        }
                        // Note: If there are no external logins, we simply render nothing.
                        // We removed the block of text telling the user to read Microsoft docs,
                        // because an end-user trying to log in doesn't care about your backend setup!
                    }
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}