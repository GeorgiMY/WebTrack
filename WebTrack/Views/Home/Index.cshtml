@{
    ViewData["Title"] = "WebTrack • Educational Demo";
}

<div class="text-center py-5 mb-5 mt-3">
    <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle mb-3" style="width: 70px; height: 70px;">
        <img src="~/images/WebTrack_icon.png" class="img-fluid w-75 h-75 object-fit-contain" alt="WebTrack logo">
    </div>
    <h1 class="display-4 fw-bold text-dark mb-3" style="letter-spacing: -1px;">WebTrack</h1>
    <p class="lead text-secondary mb-5 mx-auto" style="max-width: 600px;">
        A real-time user activity monitoring platform built to demonstrate the scary reality of online telemetry.
    </p>

    <div class="d-flex justify-content-center flex-wrap gap-3">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Websites" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-4 fw-bold shadow-sm">
                Go to Dashboard <i class="bi bi-arrow-right ms-1"></i>
            </a>
        }
        else
        {
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg rounded-pill px-4 fw-bold shadow-sm">
                Login to Track <i class="bi bi-box-arrow-in-right ms-1"></i>
            </a>
        }

        <a href="https://github.com/GeorgiMY/WebTrack" class="btn btn-dark btn-lg rounded-pill px-4 fw-bold shadow-sm" target="_blank">
            <i class="bi bi-github me-2"></i> View Source
        </a>
    </div>
</div>

<div class="row justify-content-center mb-5">
    <div class="col-lg-10">
        <div class="alert alert-danger shadow-sm border-0 d-flex gap-3 align-items-start rounded-3 p-4 mb-4">
            <i class="bi bi-shield-exclamation fs-2 text-danger"></i>
            <div>
                <h5 class="fw-bold text-danger mb-1">EDUCATIONAL PURPOSES ONLY</h5>
                <p class="mb-0 text-danger" style="opacity: 0.9;">
                    You should <strong>NOT</strong> deploy this web app. It is <strong>ONLY</strong> used to showcase how user activity can be tracked and monitored. It is not made for actual user tracking. <strong>Unauthorized tracking of individuals is highly illegal in the EU.</strong> Do not deploy this against live systems!
                </p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-5 justify-content-center">

    <div class="col-lg-10">
        <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
            <div style="height: 6px; background: linear-gradient(90deg, #4facfe 0%, #00f2fe 100%);"></div>
            <div class="card-body p-4 p-md-5">
                <h4 class="fw-bold text-dark mb-3"><i class="bi bi-info-circle text-primary me-2"></i>About WebTrack</h4>
                <p class="text-secondary mb-0" style="line-height: 1.7;">
                    <strong>WebTrack</strong> allows you to observe what each user is doing on a website in real time. Its purpose is to demonstrate how trivial it can be for a server to monitor user behaviour online-often without a visitor being aware that such monitoring is occurring.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0 rounded-3 h-100">
            <div class="card-body p-4">
                <h5 class="fw-bold text-dark mb-4"><i class="bi bi-star-fill text-warning me-2"></i>Core Features</h5>
                <ul class="list-group list-group-flush border-top-0">
                    <li class="list-group-item bg-transparent px-0 text-secondary border-bottom-0 mb-2">
                        <i class="bi bi-check-circle-fill text-success me-2"></i> Real-time event tracking
                    </li>
                    <li class="list-group-item bg-transparent px-0 text-secondary border-bottom-0 mb-2">
                        <i class="bi bi-check-circle-fill text-success me-2"></i> Live control panel for active sessions
                    </li>
                    <li class="list-group-item bg-transparent px-0 text-secondary border-bottom-0 mb-2">
                        <i class="bi bi-check-circle-fill text-success me-2"></i> Educational insights into web telemetry
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0 rounded-3 h-100">
            <div class="card-body p-4">
                <h5 class="fw-bold text-dark mb-4"><i class="bi bi-braces text-primary me-2"></i>Technologies Built With</h5>
                <ul class="list-group list-group-flush border-top-0">
                    <li class="list-group-item bg-transparent px-0 text-secondary border-bottom-0 mb-2">
                        <i class="bi bi-code-square text-primary me-2"></i> <strong>C# & ASP.NET</strong> backend logic
                    </li>
                    <li class="list-group-item bg-transparent px-0 text-secondary border-bottom-0 mb-2">
                        <i class="bi bi-lightning-charge-fill text-warning me-2"></i> <strong>SignalR</strong> real-time communication
                    </li>
                    <li class="list-group-item bg-transparent px-0 text-secondary border-bottom-0">
                        <i class="bi bi-palette-fill text-danger me-2"></i> <strong>Bootstrap 5 / TailwindCSS</strong> styling
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>