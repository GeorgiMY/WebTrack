@using Microsoft.AspNetCore.Identity

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebTrack Analytics</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebTrack.styles.css" asp-append-version="true" />

    <style>
        /* Global Dashboard Theme */
        body {
            background-color: #f4f6f9; /* Soft background */
            font-family: 'Inter', sans-serif;
            display: flex;
            flex-direction: column;
            min-height: 100vh; /* Keeps footer at bottom */
        }

        /* The signature gradient line across the top of the browser */
        .top-accent {
            height: 4px;
            background: linear-gradient(90deg, #4facfe 0%, #00f2fe 100%);
            width: 100%;
        }

        /* Modernized Navbar */
        .navbar {
            padding: 0.8rem 0;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.4rem;
            letter-spacing: -0.5px;
        }

        .nav-link {
            font-weight: 500;
            color: #5f6368 !important;
            transition: all 0.2s ease;
            padding: 0.5rem 1rem !important;
            border-radius: 6px;
        }

            .nav-link:hover, .nav-link.active {
                color: #4facfe !important;
                background-color: rgba(79, 172, 254, 0.08); /* Soft blue hover state */
            }

        .footer {
            background-color: white;
        }
    </style>
</head>
<body>
    <div class="top-accent"></div>

    <header>
        <nav class="navbar navbar-expand-lg bg-white shadow-sm mb-4">
            <div class="container-fluid container-xl">
                <a class="navbar-brand text-dark d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-activity text-primary" style="color: #4facfe !important;"></i>
                    <span>WebTrack</span>
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 gap-1 ms-lg-4 mt-3 mt-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house me-1"></i> Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Websites" asp-action="Index">
                                <i class="bi bi-window-sidebar me-1"></i> Websites
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Sessions" asp-action="Index">
                                <i class="bi bi-stopwatch me-1"></i> Sessions
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Visitors" asp-action="Index">
                                <i class="bi bi-people me-1"></i> Visitors
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                        {
                            <li class="nav-item ms-lg-2">
                                <a class="nav-link text-danger" style="background-color: rgba(220, 53, 69, 0.05);" asp-area="" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-shield-lock me-1"></i> Admin Panel
                                </a>
                            </li>
                        }
                    </ul>

                    <div class="ms-auto mt-3 mt-lg-0">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="container container-xl pb-5 flex-grow-1">
        @RenderBody()
    </main>

    <footer class="footer py-4 mt-auto border-top text-center text-muted small">
        <div class="container">
            <i class="bi bi-activity"></i> &copy; 2026 - <strong>WebTrack</strong> Dashboard. All rights reserved.
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>