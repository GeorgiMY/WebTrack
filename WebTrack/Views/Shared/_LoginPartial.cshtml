@using Microsoft.AspNetCore.Identity
@using WebTrack.Data.Entities
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<ul class="navbar-nav align-items-center gap-2">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a class="nav-link d-flex align-items-center gap-2 fw-semibold" asp-area="Identity" asp-page="/Account/Manage/Index" title="@User.Identity?.Name">
                <i class="bi bi-person-circle fs-5" style="color: #4facfe;"></i>
                <span class="d-none d-sm-inline text-dark">My Account</span>
            </a>
        </li>

        <li class="nav-item ms-lg-2">
            <form class="m-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-semibold shadow-sm d-flex align-items-center gap-1">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link fw-semibold px-3" asp-area="Identity" asp-page="/Account/Login">Sign In</a>
        </li>

        <li class="nav-item ms-lg-2">
            <a class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold" asp-area="Identity" asp-page="/Account/Register">
                Register <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </li>
    }
</ul>