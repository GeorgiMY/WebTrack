@using WebTrack.Core.DTOs.Websites
@model WebsiteCreateDto

<h2>Create Product</h2>

<form asp-controller="Websites" asp-action="Create" method="post">
    <div>
        <label asp-for="Name"></label>
        <input asp-for="Name" />
        <span asp-validation-for="Name"></span>
    </div>

    <div>
        <label asp-for="BaseUrl"></label>
        <input asp-for="BaseUrl" />
        <span asp-validation-for="BaseUrl"></span>
    </div>

    <div>
        <label asp-for="WsSecret"></label>
        <input asp-for="WsSecret" />
        <span asp-validation-for="WsSecret"></span>
    </div>

    <button type="submit">Create</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}