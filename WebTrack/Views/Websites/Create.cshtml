@using WebTrack.Core.DTOs.Websites
@model WebsiteCreateDto

<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Website - WebTrack Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />

    <style>
        body {
            background-color: #f4f6f9; /* Same soft background as the dashboard */
        }

        .form-card {
            border-radius: 12px;
            overflow: hidden;
        }

        /* The same colorful gradient accent */
        .card-accent {
            height: 6px;
            background: linear-gradient(90deg, #4facfe 0%, #00f2fe 100%);
        }

        /* Custom focus glow for inputs to match the blue theme */
        .form-control:focus {
            border-color: #4facfe;
            box-shadow: 0 0 0 0.25rem rgba(79, 172, 254, 0.25);
        }

        /* Slight grey background for inputs to make them pop out */
        .form-control {
            background-color: #f8f9fa;
        }
    </style>
</head>
<body>
    <div class="container py-5">

        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-6 col-xl-5">

                <div class="mb-4">
                    <a asp-action="Index" asp-controller="Websites" class="text-decoration-none text-secondary custom-hover">
                        <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
                    </a>
                </div>

                <div class="card form-card shadow-sm border-0">
                    <div class="card-accent"></div>

                    <div class="card-body p-4 p-md-5">
                        <h2 class="fw-bold mb-2 text-dark">Add New Website</h2>
                        <p class="text-muted mb-4 small">Register a new website to start tracking live user sessions.</p>

                        <form asp-controller="Websites" asp-action="Create" method="post">

                            <div class="mb-4">
                                <label asp-for="Name" class="form-label fw-semibold text-secondary">
                                    <i class="bi bi-window-sidebar me-1"></i> Website Name
                                </label>
                                <input asp-for="Name" class="form-control form-control-lg px-3" placeholder="e.g. My Awesome Blog" />
                                <span asp-validation-for="Name" class="text-danger small mt-1 d-block fw-semibold"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="BaseUrl" class="form-label fw-semibold text-secondary">
                                    <i class="bi bi-link-45deg me-1"></i> Base URL
                                </label>
                                <input asp-for="BaseUrl" class="form-control form-control-lg px-3" placeholder="https://example.com" />
                                <span asp-validation-for="BaseUrl" class="text-danger small mt-1 d-block fw-semibold"></span>
                            </div>

                            <div class="mb-5">
                                <label asp-for="WsSecret" class="form-label fw-semibold text-secondary">
                                    <i class="bi bi-key me-1"></i> WebSocket Secret
                                </label>
                                <input asp-for="WsSecret" class="form-control form-control-lg px-3" placeholder="A secure random string" />
                                <span asp-validation-for="WsSecret" class="text-danger small mt-1 d-block fw-semibold"></span>
                                <div class="form-text mt-2 small text-muted">
                                    <i class="bi bi-info-circle me-1"></i> This secret ensures secure communication between your site and the tracker.
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold shadow-sm">
                                <i class="bi bi-plus-lg me-2"></i> Register Website
                            </button>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>