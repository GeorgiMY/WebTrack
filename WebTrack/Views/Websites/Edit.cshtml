@using WebTrack.Core.DTOs.Websites
@model WebsiteEditDto

@{
    ViewData["Title"] = "Edit Website";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Edit Website</h2>

                <form asp-action="Update" asp-controller="Websites" method="post">
                    <input asp-for="Id" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="BaseUrl" class="form-label"></label>
                        <input asp-for="BaseUrl" class="form-control" />
                        <span asp-validation-for="BaseUrl" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="WsSecret" class="form-label"></label>
                        <input asp-for="WsSecret" class="form-control" />
                        <span asp-validation-for="WsSecret" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary rounded-pill px-4">Update Website</button>
                        <a asp-action="Index" asp-controller="Websites" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
