@using WebTrack.Core.DTOs.Sessions
@model IEnumerable<SessionListItemDto>

@{
    ViewData["Title"] = "Sessions";
}

<div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
    <div>
        <h2 class="fw-bold text-dark mb-1">Sessions</h2>
        <p class="text-muted mb-0">Real-time breakdown of user interactions.</p>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-3 overflow-hidden">
    <div style="height: 6px; background: linear-gradient(90deg, #4facfe 0%, #00f2fe 100%);"></div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 text-nowrap">
            <thead class="bg-light text-muted small text-uppercase" style="letter-spacing: 0.5px;">
                <tr>
                    <th class="py-3 ps-4">Landing Page</th>
                    <th class="py-3">Referrer</th>
                    <th class="py-3">System</th>
                    <th class="py-3">Duration</th>
                    <th class="py-3">IDs</th>
                    <th class="py-3 text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (SessionListItemDto session in Model)
                {
                    <tr>
                        <td class="ps-4 py-3 fw-semibold text-dark">
                            <i class="bi bi-file-earmark-text text-secondary me-1"></i> @session.LandingPagePath
                        </td>
                        <td class="py-3 text-muted">
                            @(string.IsNullOrEmpty(session.Referrer) ? "Direct Traffic" : session.Referrer)
                        </td>
                        <td class="py-3 small">
                            <div><i class="bi bi-globe me-1 text-primary"></i> @session.Browser</div>
                            <div><i class="bi bi-laptop me-1 text-secondary"></i> @session.Os / @session.DeviceType</div>
                        </td>
                        <td class="py-3 small text-muted">
                            <div><i class="bi bi-clock me-1"></i> Start: @session.StartedAtUtc.ToString("g")</div>
                            <div><i class="bi bi-stopwatch me-1"></i> End: @(session.EndedAtUtc?.ToString("g") ?? "Active")</div>
                        </td>
                        <td class="py-3 small font-monospace text-secondary" style="font-size: 0.8rem;">
                            <div>V: @session.VisitorId.ToString().Substring(0, 8)...</div>
                            <div>W: @session.WebsiteId.ToString().Substring(0, 8)...</div>
                        </td>
                        <td class="py-3 pe-4 text-end">
                            <form asp-action="Delete" asp-route-id="@session.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3"
                                        onclick="return confirm('Delete this session and its tracked events?');">
                                    <i class="bi bi-trash3 me-1"></i> Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>