@using WebTrack.Core.DTOs.Visitors
@using WebTrack.Data.Entities
@model IEnumerable<VisitorListItemDto>

@{
    ViewData["Title"] = "Visitors";
}

<div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
    <div>
        <h2 class="fw-bold text-dark mb-1"><i class="bi bi-people text-primary me-2"></i>Visitors</h2>
        <p class="text-muted mb-0">Track unique visitors and their journey across your websites.</p>
    </div>
    <div class="badge bg-light text-dark border px-3 py-2 rounded-pill shadow-sm">
        <i class="bi bi-bar-chart-fill text-primary me-1"></i> Total Visitors: @Model.Count()
    </div>
</div>

<div class="card shadow-sm border-0 rounded-3 overflow-hidden">
    <div style="height: 4px; background: linear-gradient(90deg, #4facfe 0%, #00f2fe 100%);"></div>

    @if (!Model.Any())
    {
        <div class="card-body text-center py-5">
            <div class="display-1 text-muted mb-3 opacity-25">
                <i class="bi bi-inbox"></i>
            </div>
            <h5 class="fw-bold text-dark">No visitors found</h5>
            <p class="text-muted">Once your tracking script is installed, visitors will appear here.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase" style="letter-spacing: 0.5px;">
                    <tr>
                        <th class="py-3 ps-4 border-bottom-0" style="width: 30%;">Visitor Identity</th>
                        <th class="py-3 border-bottom-0" style="width: 55%;">Visited Websites</th>
                        <th class="py-3 border-bottom-0 text-end pe-4" style="width: 15%;">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @{
                        int visitorIndex = 0;
                    }
                    @foreach (VisitorListItemDto visitor in Model.OrderByDescending(v => v.FirstSeenAt))
                    {
                        string collapseId = $"visitor-sites-{visitorIndex}";
                        visitorIndex++;

                        <tr>
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center">
                                    <div class="bg-secondary bg-opacity-10 text-secondary rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 45px; height: 45px;">
                                        <i class="bi bi-person-fill fs-4"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark font-monospace" style="font-size: 0.95rem;">
                                            @visitor.ConnectionId.Substring(0, Math.Min(8, visitor.ConnectionId.Length)).ToUpper()
                                        </div>
                                        <div class="text-muted small">
                                            <i class="bi bi-clock me-1"></i> First seen: @visitor.FirstSeenAt.ToLocalTime().ToString("MMM dd, yyyy")
                                        </div>
                                    </div>
                                </div>
                            </td>

                            <td class="py-3">
                                @if (visitor.Websites.Any())
                                {
                                    <button class="btn btn-sm btn-primary rounded-pill shadow-sm px-3 fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                                        @visitor.Websites.Count() Sites <i class="bi bi-chevron-down ms-1"></i>
                                    </button>
                                }
                                else
                                {
                                    <span class="badge bg-light text-secondary border rounded-pill">None</span>
                                }
                            </td>
                            <td class="py-3 pe-4 text-end">
                                <form asp-action="Delete" asp-route-id="@visitor.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3"
                                            onclick="return confirm('Delete this visitor and all related sessions/events?');">
                                        <i class="bi bi-trash3 me-1"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>

                        @if (visitor.Websites.Any())
                        {
                            <tr>
                                <td colspan="3" class="p-0 border-0">
                                    <div class="collapse" id="@collapseId">
                                        <div class="p-4 bg-light border-bottom" style="box-shadow: inset 0 4px 6px -6px rgba(0,0,0,0.1);">
                                            <h6 class="fw-bold text-secondary mb-3 text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                                                Websites and Sessions for Visitor @visitor.ConnectionId.Substring(0, Math.Min(8, visitor.ConnectionId.Length)).ToUpper()
                                            </h6>

                                            <div class="list-group shadow-sm border-0 rounded-3">
                                                @foreach (Website website in visitor.Websites.OrderBy(w => w.Name))
                                                {
                                                    List<Session> websiteSessions = visitor.Sessions
                                                        .Where(s => s.WebsiteId == website.Id)
                                                        .OrderByDescending(s => s.StartedAtUtc)
                                                        .ToList();

                                                    <div class="list-group-item border-0 border-bottom p-3">
                                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                                            <div class="fw-bold text-dark">
                                                                <i class="bi bi-window-sidebar text-primary me-2"></i>@website.Name
                                                            </div>
                                                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle rounded-pill">
                                                                @websiteSessions.Count Session@(websiteSessions.Count == 1 ? string.Empty : "s")
                                                            </span>
                                                        </div>

                                                        <div class="small text-muted font-monospace mb-2">@website.BaseUrl</div>

                                                        @if (websiteSessions.Any())
                                                        {
                                                            <ul class="list-group list-group-flush small border rounded-3 overflow-hidden">
                                                                @foreach (Session session in websiteSessions)
                                                                {
                                                                    <li class="list-group-item d-flex justify-content-between align-items-center py-2 px-3">
                                                                        <div>
                                                                            <div class="fw-semibold text-dark mb-1">
                                                                                <i class="bi bi-box-arrow-in-right text-success me-1"></i> @session.LandingPagePath
                                                                            </div>
                                                                            <div class="text-muted" style="font-size: 0.75rem;">
                                                                                <i class="bi bi-display me-1"></i> @session.Browser on @session.Os
                                                                                <span class="mx-1">•</span>
                                                                                <span class="fst-italic">via @(string.IsNullOrWhiteSpace(session.Referrer) ? "Direct" : session.Referrer)</span>
                                                                            </div>
                                                                        </div>
                                                                        <div class="text-end text-muted font-monospace" style="font-size: 0.75rem;">
                                                                            @session.StartedAtUtc.ToLocalTime().ToString("MMM dd")<br />
                                                                            @session.StartedAtUtc.ToLocalTime().ToString("HH:mm")
                                                                        </div>
                                                                    </li>
                                                                }
                                                            </ul>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted small fst-italic">No sessions recorded for this website yet.</span>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
</div>