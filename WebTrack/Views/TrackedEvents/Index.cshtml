@using WebTrack.Core.DTOs.TrackedEvents
@model IEnumerable<TrackedEventListItemDto>

@{
    ViewData["Title"] = "Tracked Events";
}

<div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
    <div>
        <h2 class="fw-bold text-dark mb-1">Tracked Events</h2>
        <p class="text-muted mb-0">Granular telemetry data and individual visitor actions.</p>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-3 overflow-hidden">
    <div style="height: 6px; background: linear-gradient(90deg, #4facfe 0%, #00f2fe 100%);"></div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 text-nowrap">
            <thead class="bg-light text-muted small text-uppercase" style="letter-spacing: 0.5px;">
                <tr>
                    <th class="py-3 ps-4">Event Type</th>
                    <th class="py-3">Target URL</th>
                    <th class="py-3">Element / Context Data</th>
                    <th class="py-3">Timestamp</th>
                    <th class="py-3">Session Ref</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var trackedEvent in Model)
                {
                    // Assign specific colors and icons based on the type of event
                    string badgeClass = "bg-secondary text-secondary";
                    string iconClass = "bi-activity";

                    switch (trackedEvent.EventType.ToLower())
                    {
                        case "click":
                            badgeClass = "bg-primary text-primary border-primary-subtle";
                            iconClass = "bi-mouse2";
                            break;
                        case "scroll":
                            badgeClass = "bg-info text-info border-info-subtle";
                            iconClass = "bi-arrows-collapse";
                            break;
                        case "pageload":
                            badgeClass = "bg-success text-success border-success-subtle";
                            iconClass = "bi-box-arrow-in-right";
                            break;
                        case "jserror":
                        case "error":
                            badgeClass = "bg-danger text-danger border-danger-subtle";
                            iconClass = "bi-bug-fill";
                            break;
                        case "input":
                            badgeClass = "bg-warning text-warning border-warning-subtle";
                            iconClass = "bi-keyboard";
                            break;
                        default:
                            badgeClass = "bg-secondary text-secondary border-secondary-subtle";
                            iconClass = "bi-record-circle";
                            break;
                    }

                    <tr>
                        <td class="ps-4 py-3">
                            <span class="badge bg-opacity-10 border rounded-pill px-3 py-2 @badgeClass" style="font-size: 0.85rem;">
                                <i class="bi @iconClass me-1"></i> @trackedEvent.EventType
                            </span>
                        </td>
                        <td class="py-3 fw-semibold text-dark">
                            <i class="bi bi-link-45deg text-muted me-1"></i> @trackedEvent.TargetUrl
                        </td>
                        <td class="py-3">
                            @if (!string.IsNullOrEmpty(trackedEvent.ElementData))
                            {
                                <div class="font-monospace small text-secondary bg-light p-1 rounded d-inline-block border">
                                    @trackedEvent.ElementData
                                </div>
                            }
                            else
                            {
                                <span class="text-muted small fst-italic">No context data</span>
                            }
                        </td>
                        <td class="py-3 small text-muted">
                            <i class="bi bi-clock me-1"></i> @trackedEvent.OccurredAtUtc.ToString("g")
                        </td>
                        <td class="py-3 small font-monospace text-secondary" style="font-size: 0.8rem;">
                            S: @trackedEvent.SessionId.ToString().Substring(0, 8)...
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>