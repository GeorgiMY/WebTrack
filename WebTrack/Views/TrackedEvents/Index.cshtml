@using WebTrack.Core.DTOs.TrackedEvents
@model IEnumerable<TrackedEventListItemDto>

@{
    ViewData["Title"] = "Tracked Events";
}

<div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
    <div>
        <h2 class="fw-bold text-dark mb-1"><i class="bi bi-activity text-primary me-2"></i>Tracked Events</h2>
        <p class="text-muted mb-0">Granular telemetry data and individual visitor actions.</p>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-3 overflow-hidden">
    <div style="height: 4px; background: linear-gradient(90deg, #4facfe 0%, #00f2fe 100%);"></div>

    @if (!Model.Any())
    {
        <div class="card-body text-center py-5">
            <div class="display-1 text-muted mb-3 opacity-25">
                <i class="bi bi-inbox"></i>
            </div>
            <h5 class="fw-bold text-dark">No tracked events found</h5>
            <p class="text-muted">Events will appear here as visitors interact with your websites.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-nowrap">
                <thead class="bg-light text-muted small text-uppercase" style="letter-spacing: 0.5px;">
                    <tr>
                        <th class="py-3 ps-4 border-bottom-0" style="width: 30%;">Session</th>
                        <th class="py-3 border-bottom-0" style="width: 35%;">Website</th>
                        <th class="py-3 border-bottom-0" style="width: 20%;">Event Types</th>
                        <th class="py-3 border-bottom-0 text-end pe-4" style="width: 15%;">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @{
                        int sessionIndex = 0;
                        var groupedSessions = Model
                            .GroupBy(trackedEvent => trackedEvent.SessionId)
                            .OrderByDescending(group => group.Max(item => item.OccurredAtUtc));
                    }

                    @foreach (var sessionGroup in groupedSessions)
                    {
                        string collapseId = $"session-events-{sessionIndex}";
                        sessionIndex++;
                        var latestEvent = sessionGroup.OrderByDescending(item => item.OccurredAtUtc).First();

                        <tr>
                            <td class="ps-4 py-3">
                                <div class="fw-bold text-dark font-monospace mb-1" style="font-size: 0.9rem;">
                                    @sessionGroup.Key
                                </div>
                                <div class="small text-muted">
                                    <i class="bi bi-clock me-1"></i>
                                    Last activity: @latestEvent.OccurredAtUtc.ToLocalTime().ToString("MMM dd, yyyy HH:mm:ss")
                                </div>
                            </td>

                            <td class="py-3">
                                <div class="fw-semibold text-dark">
                                    <i class="bi bi-window-sidebar text-primary me-2"></i>@latestEvent.WebsiteName
                                </div>
                                <div class="small text-muted font-monospace">
                                    Website ID: @latestEvent.WebsiteId
                                </div>
                            </td>

                            <td class="py-3">
                                <button class="btn btn-sm btn-primary rounded-pill shadow-sm px-3 fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                                    @sessionGroup.Count() Event Type@(sessionGroup.Count() == 1 ? string.Empty : "s") <i class="bi bi-chevron-down ms-1"></i>
                                </button>
                            </td>
                            <td class="py-3 pe-4 text-end">
                                <form asp-action="Delete" asp-route-id="@sessionGroup.Key" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3"
                                            onclick="return confirm('Delete all tracked events for this session?');">
                                        <i class="bi bi-trash3 me-1"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>

                        <tr>
                            <td colspan="4" class="p-0 border-0">
                                <div class="collapse" id="@collapseId">
                                    <div class="p-4 bg-light border-bottom" style="box-shadow: inset 0 4px 6px -6px rgba(0,0,0,0.1);">
                                        <h6 class="fw-bold text-secondary mb-3 text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                                            Event Breakdown for Session @sessionGroup.Key
                                        </h6>

                                        <div class="list-group shadow-sm border-0 rounded-3">
                                            @foreach (var trackedEvent in sessionGroup.OrderByDescending(item => item.OccurredAtUtc))
                                            {
                                                string badgeClass = "bg-secondary text-secondary border-secondary-subtle";
                                                string iconClass = "bi-activity";

                                                switch (trackedEvent.EventType.ToUpper())
                                                {
                                                    case "CLICK":
                                                        badgeClass = "bg-primary text-primary border-primary-subtle";
                                                        iconClass = "bi-mouse2";
                                                        break;
                                                    case "SCROLL":
                                                        badgeClass = "bg-info text-info border-info-subtle";
                                                        iconClass = "bi-arrows-collapse";
                                                        break;
                                                    case "INPUT":
                                                        badgeClass = "bg-warning text-warning border-warning-subtle";
                                                        iconClass = "bi-keyboard";
                                                        break;
                                                    case "DOM_UPDATE":
                                                        badgeClass = "bg-success text-success border-success-subtle";
                                                        iconClass = "bi-code-slash";
                                                        break;
                                                }

                                                <div class="list-group-item d-flex justify-content-between align-items-center p-3 border-0 border-bottom">
                                                    <div>
                                                        <span class="badge bg-opacity-10 border rounded-pill px-3 py-2 @badgeClass" style="font-size: 0.85rem;">
                                                            <i class="bi @iconClass me-1"></i> @trackedEvent.EventType
                                                        </span>
                                                    </div>

                                                    <div class="text-end">
                                                        <div>
                                                            <span class="badge bg-dark rounded-pill px-3">
                                                                @trackedEvent.EventFiredTimes fire@(trackedEvent.EventFiredTimes == 1 ? string.Empty : "s")
                                                            </span>
                                                        </div>
                                                        <div class="small text-muted mt-1">
                                                            Last occurred: @trackedEvent.OccurredAtUtc.ToLocalTime().ToString("MMM dd, yyyy HH:mm:ss")
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>